{
  "manifest_version": 3,
  "name": "Better Find",
  "version": "1.1.0",
  "description": "A professional replacement for Ctrl+F. Searches the full DOM and highlights matches cleanly.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["defaults.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "commands": {
    "open-better-find": {
      "suggested_key": {
        "default": "Ctrl+Shift+F",
        "mac": "Command+Shift+F"
      },
      "description": "Open Better Find (backup shortcut)"
    }
  },
  "permissions": ["storage"],
  "action": {
    "default_title": "Better Find — Settings"
  }
}
